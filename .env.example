# Matter API token is provided by the user in the browser — no server config needed.

# OpenRouter API key for AI-powered article categorization (optional).
# Without this, the dashboard works but articles won't be categorized.
OPENROUTER_API_KEY=

# Override the default AI models and providers (optional)
# CHAT_MODEL=meta-llama/llama-4-scout
# CHAT_MODEL_PROVIDER=groq
# EMBED_MODEL=perplexity/pplx-embed-v1-0.6b
# EMBED_MODEL_PROVIDER=
# CHAT_URL=https://openrouter.ai/api/v1/chat/completions
# EMBED_URL=https://openrouter.ai/api/v1/embeddings

# Fallback models tried in order if the primary is down/rate-limited.
# Comma-separated list of OpenRouter model IDs.
CHAT_FALLBACK_MODELS=google/gemini-2.5-flash,openai/gpt-4.1-mini
EMBED_FALLBACK_MODELS=openai/text-embedding-3-small
